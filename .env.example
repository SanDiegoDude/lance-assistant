# Lance Assistant — configuration
# Copy this to .env and edit. All variables are optional; sensible
# defaults are applied if the file is missing.

# ─── Orchestrator (OpenAI-compatible chat/completions endpoint) ──────────
# This is the agentic VLM that drives the conversation and decides when to
# call Lance for image / video / edit. It can be:
#   - LM Studio       (http://localhost:1234/v1, key blank)
#   - Ollama          (http://localhost:11434/v1, key blank)
#   - OpenAI          (https://api.openai.com/v1, key sk-...)
#   - vLLM, llama.cpp server, anything else that speaks the OpenAI API
#
# The orchestrator should be a *vision-language* model so it can see the
# images Lance produces and reason about them. Recommended local models
# (in LM Studio): qwen2.5-vl-7b-instruct, llama-3.2-11b-vision-instruct,
# pixtral-12b, mistral-small-3.1, gemma-3-12b-it. The orchestrator must
# also support OpenAI-style function calling (`tools`/`tool_calls`).
#
# If the orchestrator is unreachable or this section is blank, Lance falls
# back to its native dispatch (the Output: pills choose the task directly).
ORCHESTRATOR_BASE_URL=http://localhost:1234/v1
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_MODEL=
# blank -> auto-pick the first loaded model from /v1/models
ORCHESTRATOR_TEMPERATURE=0.7
ORCHESTRATOR_MAX_TOKENS=2048
ORCHESTRATOR_REQUEST_TIMEOUT=600

# If your orchestrator IS a vision-language model (e.g. qwen2.5-vl-7b,
# qwen3-vl-*, pixtral-12b, gemma-3-12b, llama-3.2-vision), flip this on
# so the server feeds generated/attached images back to it as image_url
# blocks. The model can then "see" what Lance just produced and respond
# more meaningfully ("here's the butterfly — want me to fix the eyes?").
# Leave off for text-only orchestrators — most local OAI servers reject
# image content blocks unless the model is a VLM.
ORCHESTRATOR_EMBED_TOOL_IMAGES=off

# ─── Lance pipeline ─────────────────────────────────────────────────────
LANCE_DEVICE=0
# Whether the text-chat fallback (extracted understanding ckpt) should be
# enabled. Only used when the orchestrator is unreachable AND a user sends
# a pure-text message. Set "off" to skip loading the ~7.6 GB ckpt entirely.
LANCE_TEXT_FALLBACK=on

# ─── Server ─────────────────────────────────────────────────────────────
WEBUI_HOST=0.0.0.0
WEBUI_PORT=7861
