# Lance Assistant — configuration
# Copy this to .env and edit. All variables are optional; sensible
# defaults are applied if the file is missing.

# ─── Orchestrator (OpenAI-compatible chat/completions endpoint) ──────────
# This is the agentic VLM that drives the conversation and decides when to
# call Lance for image / video / edit. It can be:
#   - LM Studio       (http://localhost:1234/v1, key blank)
#   - Ollama          (http://localhost:11434/v1, key blank)
#   - OpenAI          (https://api.openai.com/v1, key sk-...)
#   - vLLM, llama.cpp server, anything else that speaks the OpenAI API
#
# The orchestrator should be a *vision-language* model so it can see the
# images Lance produces and reason about them. Recommended local models
# (in LM Studio): qwen2.5-vl-7b-instruct, llama-3.2-11b-vision-instruct,
# pixtral-12b, mistral-small-3.1, gemma-3-12b-it. The orchestrator must
# also support OpenAI-style function calling (`tools`/`tool_calls`).
#
# If the orchestrator is unreachable or this section is blank, Lance falls
# back to its native dispatch (the Output: pills choose the task directly).
ORCHESTRATOR_BASE_URL=http://localhost:1234/v1
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_MODEL=
# blank -> auto-pick the first loaded model from /v1/models
ORCHESTRATOR_TEMPERATURE=0.7
ORCHESTRATOR_MAX_TOKENS=2048
ORCHESTRATOR_REQUEST_TIMEOUT=600

# If your orchestrator IS a vision-language model (e.g. qwen2.5-vl-7b,
# qwen3-vl-*, pixtral-12b, gemma-3-12b, llama-3.2-vision), flip this on.
# When enabled:
#   1. Uploaded images and videos are auto-captioned by the orchestrator
#      (a one-shot job that doesn't pollute chat history) so the agent
#      always knows what it's looking at. Videos are sampled at 1 FPS,
#      resized to 512px on the long edge, sent as a frame stack.
#   2. Generated/edited media is fed back to the orchestrator as image_url
#      blocks, and a post-job "reflection" turn fires automatically so the
#      agent reacts to what Lance just produced ("here's the butterfly —
#      want me to fix the eyes?").
# Leave off for text-only orchestrators — most local OAI servers reject
# image content blocks unless the model is a VLM. Captioning + reflection
# are skipped in that case.
ORCHESTRATOR_EMBED_TOOL_IMAGES=off

# ─── Lance pipeline ─────────────────────────────────────────────────────
LANCE_DEVICE=0
# Whether the text-chat fallback (extracted understanding ckpt) should be
# enabled. Only used when the orchestrator is unreachable AND a user sends
# a pure-text message. Set "off" to skip loading the ~7.6 GB ckpt entirely.
LANCE_TEXT_FALLBACK=on

# ByteDance ships two fine-tunes of Lance:
#   * image  -> lance_3b        — produces the crisp-text demos on the
#                                  project page; primary for image gen/edit
#   * video  -> lance_3b_video  — supports every task incl. video, but
#                                  trades some image fidelity (text is less
#                                  crisp; sometimes incoherent)
#   * auto   -> BOTH variants available; the server picks the right one
#                per task and (in --lowvram mode) hot-swaps between them.
#                On fresh installs it downloads the image checkpoint first
#                and lazy-fetches the video one when needed.
# Pick "image" if you mostly do image gen/edit and want to skip the video
# download entirely. Pick "video" if you only do video tasks. Pick "auto"
# (recommended) for the full multimodal experience.
LANCE_MODEL_VARIANT=auto

# Keep only ONE variant on the GPU at a time. The inactive variant is
# parked in system RAM and hot-swapped on demand (~2-3 s per swap on a
# 4090 with fast DDR5). Required for 24 GB cards if you want auto mode.
# Big-VRAM cards (40 GB+) should leave this off so both variants stay
# GPU-resident (no swap cost). Same effect as the --lowvram CLI flag.
# Options: 0 (default) | 1
# LANCE_LOWVRAM=0

# Model precision when loading to GPU. bf16 fits a 4090 (24 GB) comfortably
# at ~8 GB total per variant. Set to "float32" if you have a big-VRAM card
# and want max precision. Options: bfloat16 (default) | float16 | float32
# LANCE_DTYPE=bfloat16

# ─── Server ─────────────────────────────────────────────────────────────
WEBUI_HOST=0.0.0.0
WEBUI_PORT=7861
